<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelSecure.Mobile.Features.Alerts.AlertsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#080C14">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Padding="24,52,24,16" ColumnDefinitions="*,Auto"
              BackgroundColor="#080C14">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="🛡️ TRAVEL SECURE" FontSize="12" TextColor="#6B7280"
                       CharacterSpacing="1"/>
                <Label Text="Centro de Alertas" FontSize="20"
                       FontAttributes="Bold" TextColor="White"/>
            </VerticalStackLayout>
            <!-- Badge contador -->
            <Border Grid.Column="1" BackgroundColor="#EF444420"
                    Padding="10,6" StrokeThickness="1">
                <Border.Stroke>
                    <SolidColorBrush Color="#EF4444"/>
                </Border.Stroke>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="4">
                    <Ellipse Fill="#EF4444" WidthRequest="6" HeightRequest="6"
                             VerticalOptions="Center"/>
                    <Label Text="4 ACTIVAS" FontSize="10" TextColor="#EF4444"
                           FontAttributes="Bold" CharacterSpacing="1"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ═══ FILTROS ═══ -->
        <ScrollView Grid.Row="1" Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    Padding="24,0,24,14">
            <HorizontalStackLayout Spacing="8">
                <Border x:Name="FiltroTodas" BackgroundColor="#F7CA18"
                        Padding="14,8" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="Todas" FontSize="12" TextColor="#080C14"
                           FontAttributes="Bold">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltroTodas"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
                <Border BackgroundColor="#111827" Padding="14,8" StrokeThickness="1">
                    <Border.Stroke>
                        <SolidColorBrush Color="#1F2937"/>
                    </Border.Stroke>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="🚦 Tráfico" FontSize="12" TextColor="#9CA3AF">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltroTrafico"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
                <Border BackgroundColor="#111827" Padding="14,8" StrokeThickness="1">
                    <Border.Stroke>
                        <SolidColorBrush Color="#1F2937"/>
                    </Border.Stroke>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="⛈️ Clima" FontSize="12" TextColor="#9CA3AF">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltroClima"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
                <Border BackgroundColor="#111827" Padding="14,8" StrokeThickness="1">
                    <Border.Stroke>
                        <SolidColorBrush Color="#1F2937"/>
                    </Border.Stroke>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="💥 Accidentes" FontSize="12" TextColor="#9CA3AF">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltroAccidente"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
                <Border BackgroundColor="#111827" Padding="14,8" StrokeThickness="1">
                    <Border.Stroke>
                        <SolidColorBrush Color="#1F2937"/>
                    </Border.Stroke>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Label Text="🚫 Cierres" FontSize="12" TextColor="#9CA3AF">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFiltroCierre"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Border>
            </HorizontalStackLayout>
        </ScrollView>

        <!-- ═══ LISTA DE ALERTAS ═══ -->
        <ScrollView Grid.Row="2" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout x:Name="ListaAlertas"
                                 Padding="24,0,24,16" Spacing="10">

                <ActivityIndicator x:Name="LoadingAlertas"
                                   IsRunning="True" Color="#F7CA18"
                                   HorizontalOptions="Center" Margin="0,30,0,0"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ BOTTOM NAV ═══ -->
        <VerticalStackLayout Grid.Row="3" BackgroundColor="#080C14">
            <BoxView HeightRequest="1" BackgroundColor="#1F2937"/>
            <Grid ColumnDefinitions="*,*,*,*" Padding="0,10,0,28">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNavInicio"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="🏠" FontSize="20" HorizontalOptions="Center"/>
                    <Label Text="Inicio" FontSize="10" TextColor="#6B7280"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNavReporte"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="📋" FontSize="20" HorizontalOptions="Center"/>
                    <Label Text="Reportar" FontSize="10" TextColor="#6B7280"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#1A1A00" WidthRequest="44" HeightRequest="30"
                            HorizontalOptions="Center" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="🔔" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Alertas" FontSize="10" TextColor="#F7CA18"
                           FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNavPerfil"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="👤" FontSize="20" HorizontalOptions="Center"/>
                    <Label Text="Perfil" FontSize="10" TextColor="#6B7280"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
