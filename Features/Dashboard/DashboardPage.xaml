<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelSecure.Mobile.Features.Dashboard.DashboardPage"
             Shell.NavBarIsVisible="False"
             
             BackgroundColor="#080C14">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Padding="24,52,24,16" ColumnDefinitions="*,Auto,Auto"
              BackgroundColor="#080C14">
            <VerticalStackLayout Grid.Column="0" Spacing="2">
                <Label Text="Buenos días 👋" FontSize="12" TextColor="#6B7280"/>
                <Label Text="TRAVEL SECURE" FontSize="18" FontAttributes="Bold"
                       TextColor="White" CharacterSpacing="1"/>

            </VerticalStackLayout>
            <!-- Badge clima en vivo -->
            <Border Grid.Column="1"
                    BackgroundColor="#0F1D35"
                    StrokeThickness="1"
                    Padding="10,6"
                    Margin="0,0,10,0">
                <Border.Stroke>
                    <SolidColorBrush Color="#1E3A5F"/>
                </Border.Stroke>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="4">
                    <Ellipse Fill="#22C55E" WidthRequest="6" HeightRequest="6"
                             VerticalOptions="Center"/>
                    <Label Text="EN VIVO" FontSize="10" TextColor="#22C55E"
                           FontAttributes="Bold" CharacterSpacing="1"/>
                </HorizontalStackLayout>
            </Border>
            <Border Grid.Column="2"
                    BackgroundColor="#111827"
                    WidthRequest="40" HeightRequest="40"
                    StrokeThickness="1">
                <Border.Stroke>
                    <SolidColorBrush Color="#1F2937"/>
                </Border.Stroke>
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10"/>
                </Border.StrokeShape>
                <Label Text="🔔" FontSize="18"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
        </Grid>

        <!-- ═══ CONTENIDO ═══ -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="24,0,24,24" Spacing="20">

                <!-- BUSCADOR DE RUTA -->
                <Border BackgroundColor="#0F1520"
                        StrokeThickness="1"
                        Padding="20">
                    <Border.Stroke>
                        <SolidColorBrush Color="#1E2D45"/>
                    </Border.Stroke>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="🛣️" FontSize="18" VerticalOptions="Center"/>
                            <Label Text="Planificar Ruta" FontSize="16"
                                   FontAttributes="Bold" TextColor="White"
                                   VerticalOptions="Center"/>
                            <Border BackgroundColor="#F7CA18"
                                    Padding="6,2"
                                    HorizontalOptions="EndAndExpand">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="4"/>
                                </Border.StrokeShape>
                                <Label Text="NUEVO" FontSize="9" TextColor="#080C14"
                                       FontAttributes="Bold" CharacterSpacing="1"/>
                            </Border>
                        </HorizontalStackLayout>

                        <!-- Origen -->
                        <Border BackgroundColor="#111827" HeightRequest="46"
                                StrokeThickness="1">
                            <Border.Stroke>
                                <SolidColorBrush Color="#1F2937"/>
                            </Border.Stroke>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" Padding="14,0">
                                <Ellipse Grid.Column="0" Fill="#22C55E"
                                         WidthRequest="8" HeightRequest="8"
                                         VerticalOptions="Center" Margin="0,0,10,0"/>
                                <Label Grid.Column="1" Text="Tu ubicación actual"
                                       TextColor="#6B7280" FontSize="13"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Línea conectora -->
                        <BoxView BackgroundColor="#1F2937" WidthRequest="1"
                                 HeightRequest="16" HorizontalOptions="Start"
                                 Margin="20,0,0,0"/>

                        <!-- Destino -->
                        <Border BackgroundColor="#111827" HeightRequest="46"
                                StrokeThickness="1">
                            <Border.Stroke>
                                <SolidColorBrush Color="#1F2937"/>
                            </Border.Stroke>
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Grid ColumnDefinitions="Auto,*" Padding="14,0">
                                <Ellipse Grid.Column="0" Fill="#F7CA18"
                                         WidthRequest="8" HeightRequest="8"
                                         VerticalOptions="Center" Margin="0,0,10,0"/>
                                <Label Grid.Column="1" Text="¿A dónde vas hoy?"
                                       TextColor="#374151" FontSize="13"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Botón buscar -->
                        <Border HeightRequest="46" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#F7CA18" Offset="0"/>
                                    <GradientStop Color="#E8A500" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Button Text="  🔍  BUSCAR RUTA SEGURA"
                                    BackgroundColor="Transparent"
                                    TextColor="#080C14"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    Clicked="OnBuscarRuta"/>
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!--Integracion con la api nuevo apartado -->
                <Border BackgroundColor="#0F1520" StrokeThickness="1" Padding="16">
                    <Border.Stroke>
                        <SolidColorBrush Color="#1E2D45"/>
                    </Border.Stroke>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>

                    <VerticalStackLayout Spacing="10">
                        <Label Text="🛠️ PRUEBA DE API BACKEND (CLIMA)" FontSize="11" TextColor="#FFC107" FontAttributes="Bold" CharacterSpacing="1"/>

                        <Entry x:Name="TxtRutaCiudad" 
                            Placeholder="Escribe una ciudad (Ej: Lima)" 
                            TextColor="White"
                            PlaceholderColor="#4B5563"
                            BackgroundColor="#111827"
                            FontSize="13"
                            HeightRequest="40"/>
                        <Button x:Name="BtnBuscarClima"
                            Text="CONSULTAR API BACKEND"
                            Clicked="OnBtnBuscarClima"
                            BackgroundColor="#FFC107"
                            TextColor="#080C14"
                            FontAttributes="Bold"
                            FontSize="12"
                            HeightRequest="38"/>

                        <VerticalStackLayout Spacing="4" Margin="0,5,0,0"
                                    BackgroundColor="#050B14"
                                    Padding="10">

                            <Label x:Name="LblTemp"
                                Text="--°"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="#F7CA18"/>

                            <Label x:Name="LblDesc"
                                Text="Esperando consulta..."
                                FontSize="13"
                                TextColor="#22C55E"/>

                            <Label x:Name="LblCiudad"
                                Text="--"
                                FontSize="11"
                                TextColor="#9CA3AF"/>
                            <Label x:Name="LblFeelsLike"
                                Text=""
                                FontSize="11"
                                TextColor="#9CA3AF"/>

                            <Label x:Name="LblHumidity"
                                Text=""
                                FontSize="11"
                                TextColor="#9CA3AF"/>

                            <Label x:Name="LblWind"
                                Text=""
                                FontSize="11"
                                TextColor="#9CA3AF"/>

                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- CLIMA EN RUTA -->
                <Border StrokeThickness="0" Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0F2444" Offset="0"/>
                            <GradientStop Color="#0A1628" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid ColumnDefinitions="*,Auto" Padding="20">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="CLIMA EN TU RUTA" FontSize="10"
                                   TextColor="#6B7280" FontAttributes="Bold"
                                   CharacterSpacing="1.5"/>
                            <HorizontalStackLayout Spacing="10" Margin="0,4,0,0">
                                <Label x:Name="LblTempClima" Text="--°"
                                       FontSize="36" FontAttributes="Bold"
                                       TextColor="White"/>
                                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                    <Label x:Name="LblDescClima" Text="Cargando..."
                                           FontSize="13" TextColor="#9CA3AF"/>
                                    <Label x:Name="LblEstadoRuta" Text="● Verificando"
                                           FontSize="12" TextColor="#6B7280"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="8"
                                             HorizontalOptions="End"
                                             VerticalOptions="Center">
                            <Label Text="☁️" FontSize="40" HorizontalOptions="Center"/>
                            <Label Text="Lima, PE" FontSize="11"
                                   TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ESTADÍSTICAS RÁPIDAS -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                    <!-- Reportes hoy -->
                    <Border Grid.Column="0" BackgroundColor="#111827"
                            StrokeThickness="1" Padding="14,12">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1F2937"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🚨" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="12" FontSize="22" FontAttributes="Bold"
                                   TextColor="White" HorizontalOptions="Center"/>
                            <Label Text="Alertas hoy" FontSize="9"
                                   TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Rutas activas -->
                    <Border Grid.Column="1" BackgroundColor="#111827"
                            StrokeThickness="1" Padding="14,12">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1F2937"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🚗" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="48" FontSize="22" FontAttributes="Bold"
                                   TextColor="#F7CA18" HorizontalOptions="Center"/>
                            <Label Text="Conductores" FontSize="9"
                                   TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Estado vías -->
                    <Border Grid.Column="2" BackgroundColor="#111827"
                            StrokeThickness="1" Padding="14,12">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1F2937"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="🛡️" FontSize="20" HorizontalOptions="Center"/>
                            <Label Text="OK" FontSize="22" FontAttributes="Bold"
                                   TextColor="#22C55E" HorizontalOptions="Center"/>
                            <Label Text="Vías Lima" FontSize="9"
                                   TextColor="#6B7280" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- MAPA PLACEHOLDER -->
                <Border StrokeThickness="1" HeightRequest="190" Padding="0">
                    <Border.Stroke>
                        <SolidColorBrush Color="#1F2937"/>
                    </Border.Stroke>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="20"/>
                    </Border.StrokeShape>
                    <Grid>
                        <Grid.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0D1B2E" Offset="0"/>
                                <GradientStop Color="#091422" Offset="1"/>
                            </LinearGradientBrush>
                        </Grid.Background>
                        <!-- Cuadrícula de mapa simulada -->
                        <Grid RowDefinitions="*,*,*,*" ColumnDefinitions="*,*,*,*,*"
                              Opacity="0.15">
                            <BoxView Grid.Row="0" Grid.ColumnSpan="5" BackgroundColor="#4B5563" HeightRequest="1" VerticalOptions="Start"/>
                            <BoxView Grid.Row="1" Grid.ColumnSpan="5" BackgroundColor="#4B5563" HeightRequest="1" VerticalOptions="Start"/>
                            <BoxView Grid.Row="2" Grid.ColumnSpan="5" BackgroundColor="#4B5563" HeightRequest="1" VerticalOptions="Start"/>
                            <BoxView Grid.Row="3" Grid.ColumnSpan="5" BackgroundColor="#4B5563" HeightRequest="1" VerticalOptions="Start"/>
                            <BoxView Grid.RowSpan="4" Grid.Column="0" BackgroundColor="#4B5563" WidthRequest="1" HorizontalOptions="Start"/>
                            <BoxView Grid.RowSpan="4" Grid.Column="1" BackgroundColor="#4B5563" WidthRequest="1" HorizontalOptions="Start"/>
                            <BoxView Grid.RowSpan="4" Grid.Column="2" BackgroundColor="#4B5563" WidthRequest="1" HorizontalOptions="Start"/>
                            <BoxView Grid.RowSpan="4" Grid.Column="3" BackgroundColor="#4B5563" WidthRequest="1" HorizontalOptions="Start"/>
                        </Grid>
                        <!-- Pin de ubicación -->
                        <VerticalStackLayout HorizontalOptions="Center"
                                             VerticalOptions="Center" Spacing="4">
                            <Label Text="📍" FontSize="36"
                                   HorizontalOptions="Center"/>
                            <Border BackgroundColor="#F7CA18" Padding="8,4">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6"/>
                                </Border.StrokeShape>
                                <Label Text="Lima, Perú" FontSize="11"
                                       TextColor="#080C14" FontAttributes="Bold"/>
                            </Border>
                        </VerticalStackLayout>
                        <!-- Label MAPA -->
                        <Label Text="MAPA INTERACTIVO" FontSize="9"
                               TextColor="#374151" FontAttributes="Bold"
                               CharacterSpacing="2"
                               HorizontalOptions="End" VerticalOptions="End"
                               Margin="0,0,12,10"/>
                    </Grid>
                </Border>

                <!-- ALERTAS RECIENTES -->
                <Label Text="ALERTAS RECIENTES" FontSize="10" TextColor="#6B7280"
                       FontAttributes="Bold" CharacterSpacing="1.5"/>

                <Border BackgroundColor="#0F1520" StrokeThickness="1" Padding="4">
                    <Border.Stroke>
                        <SolidColorBrush Color="#1E2D45"/>
                    </Border.Stroke>
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16"/>
                    </Border.StrokeShape>
                    <VerticalStackLayout x:Name="ListaAlertas" Spacing="0">
                        <ActivityIndicator x:Name="LoadingAlertas" IsRunning="True"
                                           Color="#F7CA18" HorizontalOptions="Center"
                                           Margin="0,20,0,20"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ BOTTOM NAV BAR ═══ -->
        <Grid Grid.Row="2" BackgroundColor="#080C14">
            <BoxView HeightRequest="1" BackgroundColor="#1F2937" VerticalOptions="Start"/>
            <Grid ColumnDefinitions="*,*,*,*" Padding="0,10,0,28" Margin="0,1,0,0">

                <!-- Inicio (activo) -->
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#1A1A00" WidthRequest="44" HeightRequest="30"
                            HorizontalOptions="Center" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="🏠" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Inicio" FontSize="10" TextColor="#F7CA18"
                           FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Reportar -->
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNavReporte"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="📋" FontSize="20" HorizontalOptions="Center"/>
                    <Label Text="Reportar" FontSize="10" TextColor="#6B7280"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Alertas -->
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNavAlertas"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="🔔" FontSize="20" HorizontalOptions="Center"/>
                    <Label Text="Alertas" FontSize="10" TextColor="#6B7280"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Perfil -->
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNavPerfil"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="👤" FontSize="20" HorizontalOptions="Center"/>
                    <Label Text="Perfil" FontSize="10" TextColor="#6B7280"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </Grid>
        </Grid>

    </Grid>
</ContentPage>
