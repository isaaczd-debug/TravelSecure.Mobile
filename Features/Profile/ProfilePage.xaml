<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TravelSecure.Mobile.Features.Profile.ProfilePage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#080C14">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Padding="0,0,0,20" Spacing="0">

                <!-- ═══ HERO DEL PERFIL ═══ -->
                <Grid HeightRequest="230" Margin="0,0,0,0">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0F2444" Offset="0"/>
                            <GradientStop Color="#080C14" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>

                    <!-- Decoración circular -->
                    <Ellipse Fill="#F7CA18" Opacity="0.04"
                             WidthRequest="300" HeightRequest="300"
                             HorizontalOptions="End" VerticalOptions="Start"
                             Margin="0,-100,-80,0"/>

                    <VerticalStackLayout VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="10" Padding="0,40,0,0">

                        <!-- Avatar con badge -->
                        <Grid HorizontalOptions="Center">
                            <Border BackgroundColor="#1F2937"
                                    WidthRequest="80" HeightRequest="80"
                                    StrokeThickness="3"
                                    HorizontalOptions="Center">
                                <Border.Stroke>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F7CA18" Offset="0"/>
                                        <GradientStop Color="#E8A500" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Stroke>
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="🚛" FontSize="36"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                            <!-- Badge verificado -->
                            <Border BackgroundColor="#F7CA18"
                                    WidthRequest="22" HeightRequest="22"
                                    StrokeThickness="2"
                                    HorizontalOptions="End" VerticalOptions="End"
                                    Margin="0,0,2,2">
                                <Border.Stroke>
                                    <SolidColorBrush Color="#080C14"/>
                                </Border.Stroke>
                                <Border.StrokeShape>
                                    <Ellipse/>
                                </Border.StrokeShape>
                                <Label Text="✓" FontSize="11" TextColor="#080C14"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>
                        </Grid>

                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="Conductor Verificado"
                                   FontSize="11" TextColor="#F7CA18"
                                   HorizontalOptions="Center"
                                   CharacterSpacing="2" FontAttributes="Bold"/>
                            <Label Text="Juan Pérez Flores"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="White" HorizontalOptions="Center"/>
                            <Label Text="Licencia A-IIIa  ·  Flota Lima Sur"
                                   FontSize="12" TextColor="#6B7280"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Grid>

                <!-- ═══ ESTADÍSTICAS ═══ -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="1"
                      BackgroundColor="#111827" Margin="24,0,24,20">
                    <Grid.Shadow>
                        <Shadow Brush="#000000" Opacity="0.3" Offset="0,4" Radius="12"/>
                    </Grid.Shadow>

                    <!-- Valoración -->
                    <VerticalStackLayout Grid.Column="0" Padding="0,16" Spacing="4"
                                         HorizontalOptions="Center">
                        <Label Text="⭐ 4.98" FontSize="18" FontAttributes="Bold"
                               TextColor="#F7CA18" HorizontalOptions="Center"/>
                        <Label Text="Valoración" FontSize="10"
                               TextColor="#6B7280" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Separador vertical -->
                    <BoxView Grid.Column="0" BackgroundColor="#1F2937"
                             WidthRequest="1" HorizontalOptions="End"/>

                    <!-- Viajes -->
                    <VerticalStackLayout Grid.Column="1" Padding="0,16" Spacing="4"
                                         HorizontalOptions="Center">
                        <Label Text="842" FontSize="18" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="Viajes" FontSize="10"
                               TextColor="#6B7280" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <BoxView Grid.Column="1" BackgroundColor="#1F2937"
                             WidthRequest="1" HorizontalOptions="End"/>

                    <!-- Reportes -->
                    <VerticalStackLayout Grid.Column="2" Padding="0,16" Spacing="4"
                                         HorizontalOptions="Center">
                        <Label Text="127" FontSize="18" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center"/>
                        <Label Text="Reportes" FontSize="10"
                               TextColor="#6B7280" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- ═══ AJUSTES: ALERTAS ═══ -->
                <VerticalStackLayout Padding="24,0,24,0" Spacing="10">

                    <Label Text="ALERTAS DE NAVEGACIÓN" FontSize="10"
                           TextColor="#6B7280" FontAttributes="Bold"
                           CharacterSpacing="1.5" Margin="0,0,0,4"/>

                    <!-- Toggle Tráfico -->
                    <Border BackgroundColor="#111827" StrokeThickness="1" Padding="16,12">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1F2937"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="🚦" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,14,0"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Anomalías de Tráfico" FontSize="14"
                                       TextColor="White"/>
                                <Label Text="Recibe alertas de congestión en tu ruta"
                                       FontSize="11" TextColor="#6B7280"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" x:Name="SwitchTrafico"
                                    IsToggled="True"
                                    OnColor="#F7CA18"
                                    ThumbColor="White"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Toggle Clima -->
                    <Border BackgroundColor="#111827" StrokeThickness="1" Padding="16,12">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1F2937"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="⛈️" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,14,0"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Clima Severo" FontSize="14"
                                       TextColor="White"/>
                                <Label Text="Alertas de lluvia, niebla y huaicos"
                                       FontSize="11" TextColor="#6B7280"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" x:Name="SwitchClima"
                                    IsToggled="True"
                                    OnColor="#F7CA18"
                                    ThumbColor="White"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Toggle Radares -->
                    <Border BackgroundColor="#111827" StrokeThickness="1" Padding="16,12">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1F2937"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="📡" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,14,0"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Avisos de Radares" FontSize="14"
                                       TextColor="White"/>
                                <Label Text="Puntos de control en carretera"
                                       FontSize="11" TextColor="#6B7280"/>
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" x:Name="SwitchRadares"
                                    IsToggled="False"
                                    OnColor="#F7CA18"
                                    ThumbColor="White"
                                    VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Sección preferencias -->
                    <Label Text="PREFERENCIAS" FontSize="10"
                           TextColor="#6B7280" FontAttributes="Bold"
                           CharacterSpacing="1.5" Margin="0,12,0,4"/>

                    <!-- Modo nocturno -->
                    <Border BackgroundColor="#111827" StrokeThickness="1" Padding="16,12">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1F2937"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="🌙" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,14,0"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Modo Conducción Nocturna" FontSize="14"
                                       TextColor="White"/>
                                <Label Text="Automático" FontSize="11"
                                       TextColor="#F7CA18"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="#374151" VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Idioma -->
                    <Border BackgroundColor="#111827" StrokeThickness="1" Padding="16,12">
                        <Border.Stroke>
                            <SolidColorBrush Color="#1F2937"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="🌍" FontSize="20"
                                   VerticalOptions="Center" Margin="0,0,14,0"/>
                            <VerticalStackLayout Grid.Column="1" Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="Idioma" FontSize="14" TextColor="White"/>
                                <Label Text="Español (Perú)" FontSize="11"
                                       TextColor="#6B7280"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="#374151" VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Cerrar sesión -->
                    <Border BackgroundColor="#1A0D0D" StrokeThickness="1"
                            Padding="16,14" Margin="0,12,0,0">
                        <Border.Stroke>
                            <SolidColorBrush Color="#3B0D0D"/>
                        </Border.Stroke>
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCerrarSesion"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                            <Label Text="↪️" FontSize="18" VerticalOptions="Center"/>
                            <Label Text="Cerrar Sesión" FontSize="15"
                                   TextColor="#EF4444" FontAttributes="Bold"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Versión -->
                    <Label Text="Travel Secure v1.0.0  ·  Hecho en Perú 🇵🇪"
                           FontSize="11" TextColor="#1F2937"
                           HorizontalOptions="Center" Margin="0,16,0,0"/>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ═══ BOTTOM NAV ═══ -->
        <VerticalStackLayout Grid.Row="1" BackgroundColor="#080C14">
            <BoxView HeightRequest="1" BackgroundColor="#1F2937"/>
            <Grid ColumnDefinitions="*,*,*,*" Padding="0,10,0,28">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNavInicio"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="🏠" FontSize="20" HorizontalOptions="Center"/>
                    <Label Text="Inicio" FontSize="10" TextColor="#6B7280" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNavReporte"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="📋" FontSize="20" HorizontalOptions="Center"/>
                    <Label Text="Reportar" FontSize="10" TextColor="#6B7280" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnNavAlertas"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="🔔" FontSize="20" HorizontalOptions="Center"/>
                    <Label Text="Alertas" FontSize="10" TextColor="#6B7280" HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                    <Border BackgroundColor="#1A1A00" WidthRequest="44" HeightRequest="30"
                            HorizontalOptions="Center" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="👤" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="Perfil" FontSize="10" TextColor="#F7CA18"
                           FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>
        </VerticalStackLayout>

    </Grid>
</ContentPage>
